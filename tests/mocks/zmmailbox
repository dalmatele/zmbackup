#!/bin/bash
# zmmailbox mock
if [ "${MOCK_ZMMAILBOX_FAIL:-0}" = "1" ]; then
  echo "ERROR: connection refused" >&2
  exit 1
fi
# For getRestURL, create a non-empty tgz file if output path is specified
for i in "$@"; do
  if [[ "$i" == --output ]]; then
    : # next arg is the output file
  elif [[ "$i" == *.tgz ]]; then
    if [ "${MOCK_ZMMAILBOX_EMPTY:-0}" = "1" ]; then
      touch "$i"
    else
      echo "mock tgz content" > "$i"
    fi
  fi
done
exit 0
